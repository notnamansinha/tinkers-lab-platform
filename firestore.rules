rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ================================================================
    // HELPER FUNCTIONS — evaluated server-side, no extra reads needed
    // ================================================================

    // Is the user signed in?
    function isAuth() {
      return request.auth != null;
    }

    // Is this the user's own document?
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // Get the calling user's role from their profile
    // NOTE: This costs 1 read per rule that calls it. Minimise usage.
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Admin roles: can do anything
    function isAdmin() {
      return isAuth() && getUserRole() == 'super_admin';
    }

    // Staff roles: elevated access
    function isStaff() {
      return isAuth() && getUserRole() in ['super_admin', 'faculty', 'lab_assistant'];
    }

    // ================================================================
    // USERS COLLECTION
    // ================================================================
    match /users/{uid} {
      // Anyone authenticated can read their own profile
      allow read: if isOwner(uid) || isAdmin();
      // Users can create their own profile on registration
      allow create: if isOwner(uid) && request.resource.data.keys().hasAll(['email', 'displayName', 'role', 'isActive', 'createdAt']) && request.resource.data.role == 'student';
      // Users can update only their own non-sensitive fields; admins can update anything
      allow update: if (isOwner(uid) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isActive']))
                    || isAdmin();
      // Only admins can delete users
      allow delete: if isAdmin();
    }

    // ================================================================
    // EQUIPMENT COLLECTION
    // ================================================================
    match /equipment/{equipmentId} {
      // Any authenticated user can read equipment
      allow read: if isAuth();
      // Only staff can create/update/delete
      allow create, update, delete: if isStaff();
    }

    // ================================================================
    // BOOKINGS COLLECTION
    // ================================================================
    match /bookings/{bookingId} {
      // Authenticated users can read their own bookings; staff can read all
      allow read: if isAuth() && (resource.data.userId == request.auth.uid || isStaff());
      // Authenticated users can create bookings for themselves
      allow create: if isAuth()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.keys().hasAll(['equipmentId', 'date', 'startTime', 'endTime', 'purpose', 'status'])
                    && request.resource.data.status == 'pending';
      // Users can cancel their own bookings; staff can approve/reject/update
      allow update: if isAuth() && (
        (resource.data.userId == request.auth.uid && request.resource.data.status == 'cancelled')
        || isStaff()
      );
      // Only admins can delete bookings
      allow delete: if isAdmin();
    }

    // ================================================================
    // INVENTORY COLLECTION
    // ================================================================
    match /inventory/{itemId} {
      // Any authenticated user can read inventory (needed for checkout)
      allow read: if isAuth();
      // Only staff can create/update
      allow create, update: if isStaff();
      // Only admins can delete
      allow delete: if isAdmin();
    }

    // ================================================================
    // INVENTORY TRANSACTIONS COLLECTION
    // ================================================================
    match /inventoryTransactions/{txId} {
      // Any authenticated user can read and write transactions
      // (Checkout/return is done by any signed-in user)
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ================================================================
    // MAINTENANCE COLLECTION
    // ================================================================
    match /maintenance/{recordId} {
      // Any authenticated user can read maintenance records
      allow read: if isAuth();
      // Only staff can create/update/delete
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    // ================================================================
    // WORKSHOPS COLLECTION
    // ================================================================
    match /workshops/{workshopId} {
      // Any authenticated user can read workshops
      allow read: if isAuth();
      // Only staff can create/update/delete workshops
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    // ================================================================
    // WORKSHOP REGISTRATIONS COLLECTION
    // ================================================================
    match /workshopRegistrations/{regId} {
      // Users can read their own registrations; staff can read all
      allow read: if isAuth() && (resource.data.userId == request.auth.uid || isStaff());
      // Users can register themselves
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      // Staff can update (attendance, certificate); users can cancel their own
      allow update: if isStaff() || (isAuth() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ================================================================
    // PROJECTS COLLECTION
    // ================================================================
    match /projects/{projectId} {
      // Any authenticated user can read projects
      allow read: if isAuth();
      // Users can submit their own projects; auto-status = pending
      allow create: if isAuth()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.status == 'pending';
      // Users can edit their own pending/active projects (not status); admins can change anything
      allow update: if isAuth() && (
        (resource.data.userId == request.auth.uid && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status']))
        || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ================================================================
    // NOTIFICATIONS COLLECTION
    // ================================================================
    match /notifications/{notifId} {
      // Users can only read their own notifications
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      // Only server/admin creates notifications
      allow create: if isAdmin();
      // Users can mark their own as read (update isRead field only)
      allow update: if isAuth() && resource.data.userId == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
      allow delete: if isAdmin();
    }

    // ================================================================
    // ANNOUNCEMENTS COLLECTION
    // ================================================================
    match /announcements/{announcementId} {
      // Any authenticated user can read active announcements
      allow read: if isAuth();
      // Only staff can create/update/delete announcements
      allow create, update, delete: if isStaff();
    }

    // ================================================================
    // ISSUES COLLECTION
    // ================================================================
    match /issues/{issueId} {
      // Users can read their own issues; staff can read all
      allow read: if isAuth() && (resource.data.userId == request.auth.uid || isStaff());
      // Any authenticated user can report an issue
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      // Staff can update status; users cannot edit after submission
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    // ================================================================
    // AUDIT LOGS COLLECTION (append-only)
    // ================================================================
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      // Anyone authenticated can create (append-only, no update/delete)
      allow create: if isAuth();
      allow update, delete: if false; // Immutable
    }

    // ================================================================
    // SETTINGS COLLECTION
    // ================================================================
    match /settings/{settingId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ================================================================
    // DEFAULT DENY — deny everything else
    // ================================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
