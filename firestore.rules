rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ================================================================
    // HELPER FUNCTIONS — evaluated server-side, no extra reads needed
    // ================================================================

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // NOTE: costs 1 read per rule call — minimise usage
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuth() && getUserRole() == 'super_admin';
    }

    function isStaff() {
      return isAuth() && getUserRole() in ['super_admin', 'faculty', 'lab_assistant'];
    }

    // ================================================================
    // USERS COLLECTION
    // ================================================================
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      // New users self-create with role='student' only
      allow create: if isOwner(uid)
                    && request.resource.data.keys().hasAll(['email', 'displayName', 'role', 'userType', 'isActive', 'createdAt'])
                    && request.resource.data.role == 'student';
      // Users update their own non-sensitive fields; admins update anything
      allow update: if (isOwner(uid) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isActive']))
                    || isAdmin();
      allow delete: if isAdmin();
    }

    // ================================================================
    // EQUIPMENT COLLECTION
    // ================================================================
    match /equipment/{equipmentId} {
      allow read: if isAuth();
      allow create, update, delete: if isStaff();
    }

    // ================================================================
    // BOOKINGS COLLECTION  (Form 2A — Tier 1 machines only)
    // ================================================================
    match /bookings/{bookingId} {
      allow read: if isAuth() && (resource.data.userId == request.auth.uid || isStaff());
      // Auto-confirm model (Spec 2): status must be 'approved' on create, not 'pending'
      allow create: if isAuth()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.keys().hasAll(['equipmentId', 'machineId', 'date', 'startTime', 'endTime', 'purpose', 'projectId', 'status', 'safetyAgreementAccepted'])
                    && request.resource.data.status == 'approved'
                    && request.resource.data.safetyAgreementAccepted == true;
      // Users can cancel own bookings; staff can fully update
      allow update: if isAuth() && (
        (resource.data.userId == request.auth.uid && request.resource.data.status == 'cancelled')
        || isStaff()
      );
      allow delete: if isAdmin();
    }

    // ================================================================
    // TOOL CHECKOUTS COLLECTION  (Form 2B — Tier 2 tools only)
    // ================================================================
    match /toolCheckouts/{checkoutId} {
      allow read: if isAuth() && (resource.data.userId == request.auth.uid || isStaff());
      allow create: if isAuth()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.keys().hasAll(['toolName', 'toolCategory', 'action', 'projectId', 'locationOfUse', 'conditionAtCheckout']);
      // Users can update their own checkout (return action); staff can update any
      allow update: if isAuth() && (resource.data.userId == request.auth.uid || isStaff());
      allow delete: if isAdmin();
    }

    // ================================================================
    // INVENTORY COLLECTION  (admin stock management)
    // ================================================================
    match /inventory/{itemId} {
      allow read: if isAuth();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    // ================================================================
    // INVENTORY TRANSACTIONS COLLECTION  (admin stock movements only)
    // ================================================================
    match /inventoryTransactions/{txId} {
      allow read: if isAuth();
      // Only staff create transactions (restock/adjustment/damage) — NOT users doing checkouts
      allow create: if isStaff();
      allow update, delete: if isAdmin();
    }

    // ================================================================
    // MAINTENANCE COLLECTION
    // ================================================================
    match /maintenance/{recordId} {
      allow read: if isAuth();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    // ================================================================
    // WORKSHOPS COLLECTION
    // ================================================================
    match /workshops/{workshopId} {
      allow read: if isAuth();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    // ================================================================
    // WORKSHOP REGISTRATIONS COLLECTION
    // ================================================================
    match /workshopRegistrations/{regId} {
      allow read: if isAuth() && (resource.data.userId == request.auth.uid || isStaff());
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isStaff() || (isAuth() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ================================================================
    // PROJECTS COLLECTION  (Form 1 — Project Registration)
    // ================================================================
    match /projects/{projectId} {
      allow read: if isAuth();
      // Users self-register projects; status must start as 'pending'
      allow create: if isAuth()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.status == 'pending'
                    && request.resource.data.safetyAgreementAccepted == true
                    && request.resource.data.termsAccepted == true;
      // Users edit own pending/active projects (not status); admins change anything
      allow update: if isAuth() && (
        (resource.data.userId == request.auth.uid && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status']))
        || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ================================================================
    // NOTIFICATIONS COLLECTION
    // ================================================================
    match /notifications/{notifId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      // In-app notifications created by staff/admin only (Phase 9 email deferred)
      allow create: if isStaff();
      // Users mark their own as read (isRead field only)
      allow update: if isAuth() && resource.data.userId == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
      allow delete: if isAdmin();
    }

    // ================================================================
    // ANNOUNCEMENTS COLLECTION
    // ================================================================
    match /announcements/{announcementId} {
      allow read: if isAuth();
      allow create, update, delete: if isStaff();
    }

    // ================================================================
    // ISSUES COLLECTION  (Form 4 — Report an Issue / Suggestion)
    // ================================================================
    match /issues/{issueId} {
      allow read: if isAuth() && (resource.data.userId == request.auth.uid || isStaff());
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      // Staff update status/resolution; users cannot edit after submission
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    // ================================================================
    // AUDIT LOGS COLLECTION  (append-only, immutable)
    // ================================================================
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuth();
      allow update, delete: if false; // Immutable
    }

    // ================================================================
    // SETTINGS COLLECTION
    // ================================================================
    match /settings/{settingId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ================================================================
    // DEFAULT DENY
    // ================================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
